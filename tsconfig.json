{
	"compilerOptions": {
		"baseUrl": "./src",
		"strictPropertyInitialization": false,
		"target": "ES2024",
		"module": "NodeNext",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"declaration": true,
		"paths": {
			"@client/*": ["client/*"],
			"@constants/*": ["constants/*"],
			"@managers/*": ["managers/*"],
			"@structures/*": ["structures/*"],
			"@typescript/*": ["typescript/*"],
			"@utils/*": ["utils/*"]
		}
	}
}
